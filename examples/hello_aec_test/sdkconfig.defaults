# CUBE32 sdkconfig.defaults — hello_aec_test
# Applied first by ESP-IDF; target-specific overrides go in sdkconfig.defaults.<target>

# ---------------------------------------------------------------------------
# [ALWAYS ON] Compiler
# ---------------------------------------------------------------------------
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_COMPILER_CXX_EXCEPTIONS=y
CONFIG_COMPILER_CXX_EXCEPTIONS_EMG_POOL_SIZE=1024
CONFIG_COMPILER_CXX_RTTI=y

# ---------------------------------------------------------------------------
# [ALWAYS ON] Bootloader
# ---------------------------------------------------------------------------
CONFIG_BOOTLOADER_COMPILER_OPTIMIZATION_PERF=y
CONFIG_BOOTLOADER_LOG_LEVEL_NONE=y
CONFIG_BOOTLOADER_SKIP_VALIDATE_ALWAYS=y
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# ---------------------------------------------------------------------------
# [ALWAYS ON] Partition table — standard CUBE32 16 MB layout
# ---------------------------------------------------------------------------
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000

# ---------------------------------------------------------------------------
# [ALWAYS ON] FreeRTOS
# ---------------------------------------------------------------------------
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# ---------------------------------------------------------------------------
# [ALWAYS ON] Newlib — smaller footprint
# ---------------------------------------------------------------------------
CONFIG_NEWLIB_NANO_FORMAT=y

# ---------------------------------------------------------------------------
# [ALWAYS ON] UART ISR in IRAM — prevents UART FIFO overflow during flash
# ---------------------------------------------------------------------------
CONFIG_UART_ISR_IN_IRAM=y

# ---------------------------------------------------------------------------
# CUBE32 Board — always required
# ---------------------------------------------------------------------------
CONFIG_CUBE32_BOARD_S3_CORE=y

# ---------------------------------------------------------------------------
# CUBE32 Subsystems
# ---------------------------------------------------------------------------
CONFIG_CUBE32_DISPLAY_ENABLED=y
CONFIG_CUBE32_DISPLAY_CUBE_TFT_TOUCH_154=y

CONFIG_CUBE32_LVGL_ENABLED=y
CONFIG_CUBE32_TOUCH_ENABLED=y
CONFIG_CUBE32_IMU_ENABLED=n
CONFIG_CUBE32_MAG_ENABLED=n
CONFIG_CUBE32_AUDIO_ENABLED=y
CONFIG_CUBE32_SDCARD_ENABLED=y
CONFIG_CUBE32_CAMERA_ENABLED=n
CONFIG_CUBE32_MODEM_ENABLED=n
CONFIG_CUBE32_PMU_ENABLED=y
CONFIG_CUBE32_BLE_OTA_ENABLED=y
CONFIG_CUBE32_ADC_BUTTON_ENABLED=n

# ---------------------------------------------------------------------------
# [OPTIONAL] Audio codec I2C
# ---------------------------------------------------------------------------
CONFIG_CODEC_I2C_BACKWARD_COMPATIBLE=n

# ---------------------------------------------------------------------------
# [ALWAYS ON] Bluetooth — NimBLE required by CUBE32_BLE_OTA_ENABLED
# ---------------------------------------------------------------------------
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=y
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_INTERNAL=y
CONFIG_BT_NIMBLE_ATT_PREFERRED_MTU=512
CONFIG_BT_NIMBLE_TRANSPORT_ACL_SIZE=512
CONFIG_BT_NIMBLE_MSYS_1_BLOCK_COUNT=24
CONFIG_BT_NIMBLE_MSYS_2_BLOCK_COUNT=32

# ---------------------------------------------------------------------------
# LVGL 9.x — widgets and fonts for hello_aec_test UI
# Fonts: 10+20+24 required by ble_ota_ui.cpp; 12+14 used by AEC test UI
# Widgets: dropdown (mode selector), checkbox (tone toggle),
#          bar (progress), slider (volume)
# ---------------------------------------------------------------------------
CONFIG_LV_OS_NONE=y
CONFIG_LV_USE_CLIB_MALLOC=y
CONFIG_LV_USE_CLIB_STRING=y
CONFIG_LV_USE_CLIB_SPRINTF=y
CONFIG_LV_USE_IMGFONT=y
CONFIG_LV_USE_ASSERT_STYLE=y
CONFIG_LV_FONT_FMT_TXT_LARGE=y
CONFIG_LV_USE_FONT_COMPRESSED=n
CONFIG_LV_USE_FONT_PLACEHOLDER=n
CONFIG_LV_FONT_MONTSERRAT_10=y
CONFIG_LV_FONT_MONTSERRAT_12=y
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_USE_LODEPNG=y
CONFIG_LV_USE_ANIMIMG=n
CONFIG_LV_USE_CALENDAR=n
CONFIG_LV_USE_CALENDAR_HEADER_ARROW=n
CONFIG_LV_USE_CALENDAR_HEADER_DROPDOWN=n
CONFIG_LV_USE_CHART=n
CONFIG_LV_USE_KEYBOARD=n
CONFIG_LV_USE_LED=n
CONFIG_LV_USE_LIST=n
CONFIG_LV_USE_MENU=n
CONFIG_LV_USE_MSGBOX=n
CONFIG_LV_USE_SPAN=n
CONFIG_LV_USE_SPINBOX=n
CONFIG_LV_USE_SPINNER=n
CONFIG_LV_USE_TABVIEW=n
CONFIG_LV_USE_TILEVIEW=n
CONFIG_LV_USE_WIN=n
CONFIG_LV_BUILD_EXAMPLES=n
CONFIG_LV_USE_DROPDOWN=y
CONFIG_LV_USE_CHECKBOX=y
CONFIG_LV_USE_BAR=y
CONFIG_LV_USE_SLIDER=y
