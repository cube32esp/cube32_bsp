# CUBE32 sdkconfig.defaults.esp32s3 — ESP32-S3 specific settings
# Applied after sdkconfig.defaults when target is esp32s3.
# For future chip support, create sdkconfig.defaults.esp32p4 etc. alongside this file.

# ---------------------------------------------------------------------------
# Flash
# ---------------------------------------------------------------------------
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y

# ---------------------------------------------------------------------------
# CPU
# ---------------------------------------------------------------------------
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# ---------------------------------------------------------------------------
# PSRAM — Octal SPI RAM (8 MB on CUBE32-S3 Core)
# ---------------------------------------------------------------------------
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=512
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=65536
CONFIG_SPIRAM_MEMTEST=n

# ---------------------------------------------------------------------------
# Cache — larger instruction cache improves PSRAM throughput
# ---------------------------------------------------------------------------
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=y
CONFIG_ESP32S3_DATA_CACHE_LINE_64B=y

# ---------------------------------------------------------------------------
# MbedTLS — allocate buffers in external PSRAM
# ---------------------------------------------------------------------------
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y

# ---------------------------------------------------------------------------
# WiFi — further reduce internal RAM usage (SPIRAM available for buffers)
# ---------------------------------------------------------------------------
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=3
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=6
CONFIG_ESP_WIFI_RX_BA_WIN=3
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=16

# ---------------------------------------------------------------------------
# System event task — reduce stack (less contention with LVGL + audio tasks)
# ---------------------------------------------------------------------------
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
