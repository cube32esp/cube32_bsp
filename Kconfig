    menu "Robot Head Configuration"
        config CUBE32_ROBOT_HEAD_ENABLED
            bool "Enable Robot Head Action Engine"
            default n
            depends on CUBE32_SERVO_ENABLED && CUBE32_SERVO_NUM_CHANNELS = 2
            help
                Enable the robot head simulation action engine.
                Uses 2 servos as a pan/tilt chassis for head expressions
                such as nod, shake, curious, and attention.
                Requires PWM Servo with 2 channels enabled.

        config CUBE32_ROBOT_HEAD_PAN_CHANNEL
            int "Pan Servo Channel (horizontal)"
            default 0
            range 0 1
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Servo channel for horizontal pan (head turning left/right).

        config CUBE32_ROBOT_HEAD_TILT_CHANNEL
            int "Tilt Servo Channel (vertical)"
            default 1
            range 0 1
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Servo channel for vertical tilt (head nodding up/down).

        config CUBE32_ROBOT_HEAD_PAN_CENTER
            int "Pan Center Angle (degrees)"
            default 90
            range 0 360
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Center (forward-facing) position for pan servo in degrees.
                For 360° continuous servos, 90 = stop.

        config CUBE32_ROBOT_HEAD_TILT_CENTER
            int "Tilt Center Angle (degrees)"
            default 90
            range 0 180
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
