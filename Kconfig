    menu "IMU Configuration"
        config CUBE32_IMU_ENABLED
            bool "Enable IMU (LSM6DSO)"
            default n
            help
                Enable 6-axis IMU (accelerometer + gyroscope) driver initialization.
                Uses the LSM6DSO sensor via I2C at address 0x6A.

        config CUBE32_IMU_MLC_ENABLED
            bool "Enable Machine Learning Core (MLC)"
            default n
            depends on CUBE32_IMU_ENABLED
            help
                Enable the LSM6DSOX Machine Learning Core (MLC) support.
                MLC runs on-sensor decision tree inference for activity
                recognition, gesture detection, and other classification tasks.
                UCF configuration files are loaded at runtime to program the
                decision trees. MLC output is polled (no INT pins on CUBE32).

        config CUBE32_MLC_DEBUG
            bool "MLC diagnostic logging"
            default n
            depends on CUBE32_IMU_MLC_ENABLED
            help
                Enable verbose MLC register dump at startup.
                Logs CTRL1_XL, EMB_FUNC_EN_B, program memory
                readback, etc. Useful for debugging UCF loading.
    endmenu

