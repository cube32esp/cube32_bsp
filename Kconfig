    menu "BLE OTA Configuration"
        config CUBE32_BLE_OTA_ENABLED
            bool "Enable BLE OTA"
            default y
            help
                Enable BLE-based OTA firmware update and command interface.
                Uses NimBLE stack for BLE communication.

                PREREQUISITE: In menuconfig, enable
                  Component config → Bluetooth → Bluetooth → NimBLE - BLE only

                Features:
                - BLE GATT server with OTA service
                - Command/Response communication via custom characteristic
                - OTA firmware updates from BLE client
                - Double-reset detection for BLE OTA trigger
                - System restart and power off commands

                BLE Clients:
                - Python client (Bleak library) for Mac/Windows/Linux
                - Mobile apps (Android/iOS)

        config CUBE32_BLE_OTA_DOUBLE_BOOT_ENABLE
            bool "Start BLE OTA on Double Boot"
            default n
            depends on CUBE32_BLE_OTA_ENABLED
            help
                When enabled, BLE OTA will automatically start if the
                device is booted twice within the configured time gap.
                This allows entering BLE OTA mode without code changes.
                
                To trigger:
                1. Press reset button
                2. Wait less than "Double Boot Time Gap"
                3. Press reset button again
                4. BLE OTA will start automatically

        config CUBE32_BLE_OTA_DOUBLE_BOOT_TIME_MS
            int "Double Boot Time Gap (ms)"
            default 5000
            range 1000 10000
            depends on CUBE32_BLE_OTA_DOUBLE_BOOT_ENABLE
            help
                Time window in milliseconds to detect double boot.
                If device is booted twice within this time, BLE OTA starts.
                Default: 5000ms (5 seconds)

        config CUBE32_BLE_OTA_MTU_SIZE
            int "BLE MTU Size"
            default 512
            range 23 517
            depends on CUBE32_BLE_OTA_ENABLED
            help
                Maximum Transmission Unit size for BLE GATT.
                Larger MTU improves OTA transfer speed.
                517 is the maximum for NimBLE.

    endmenu

    menu "PWM Servo Configuration"
        config CUBE32_SERVO_ENABLED
            bool "Enable PWM Servo Driver"
            default n
            help
                Enable PWM servo control using ESP32-S3 LEDC hardware.
                Supports up to 2 independent servo channels.
                
                Features:
                - Hardware LEDC PWM (zero CPU overhead)
                - Support for 90°, 180°, and 360° (continuous rotation) servos
                - Angle control with configurable pulse width range
                - Speed-controlled smooth rotation

        config CUBE32_SERVO_NUM_CHANNELS
            int "Number of Servo Channels"
            default 2
            range 1 2
            depends on CUBE32_SERVO_ENABLED
            help
                Number of servo channels to configure (1 or 2).

        config CUBE32_SERVO1_PIN
