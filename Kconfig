        config CUBE32_ROBOT_HEAD_TILT_MIN
            int "Tilt Minimum Angle (degrees)"
            default 60
            range 0 180
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Minimum tilt angle allowed (physical limit of chassis).
                This limits how far down the head can nod.

        config CUBE32_ROBOT_HEAD_TILT_MAX
            int "Tilt Maximum Angle (degrees)"
            default 120
            range 0 180
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Maximum tilt angle allowed (physical limit of chassis).
                This limits how far up the head can tilt.

        config CUBE32_ROBOT_HEAD_PAN_SPEED
            int "Pan Speed Limit (1-100%)"
            default 50
            range 1 100
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Global speed scaling for pan (horizontal) movements.
                Keyframe speeds are multiplied by this percentage.
                Lower values make pan movements slower and smoother,
                reducing mechanical instability of the chassis.

        config CUBE32_ROBOT_HEAD_TILT_SPEED
            int "Tilt Speed Limit (1-100%)"
            default 50
            range 1 100
            depends on CUBE32_ROBOT_HEAD_ENABLED
            help
                Global speed scaling for tilt (vertical) movements.
                Keyframe speeds are multiplied by this percentage.
                Lower values make tilt movements slower and smoother.
    endmenu

