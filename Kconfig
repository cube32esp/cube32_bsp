menu "CUBE32 Board Configuration"

    choice CUBE32_BOARD_MODEL
        prompt "Board Model"
        default CUBE32_BOARD_S3_CORE
        help
            Select the CUBE32 board model variant.

        config CUBE32_BOARD_S3_CORE
            bool "CUBE32-S3 Core"
            help
                CUBE32-S3 Core board based on ESP32-S3.
    endchoice

    config CUBE32_BOARD_NAME
        string
        default "CUBE32-S3 Core" if CUBE32_BOARD_S3_CORE
        help
            Board name string derived from the selected board model.
            Used for logging and identification at runtime.

    menu "Display Configuration"
        config CUBE32_DISPLAY_ENABLED
            bool "Enable Display"
            default y
            help
                Enable display driver initialization.

        choice CUBE32_DISPLAY_BOARD_MODEL
            prompt "Display Board Model"
            default CUBE32_DISPLAY_CUBE_TFT_TOUCH_154
            depends on CUBE32_DISPLAY_ENABLED
            help
                Select the display board model.

            config CUBE32_DISPLAY_CUBE_TFT_TOUCH_154
                bool "CUBE_TFT_TOUCH_154 (240x240)"
                help
                    1.54 inch TFT display with touch, 240x240 resolution.

            config CUBE32_DISPLAY_CUBE_TFT_TOUCH_200
                bool "CUBE_TFT_TOUCH_200 (240x320)"
                help
                    2.0 inch TFT display with touch, 240x320 resolution.
        endchoice

        config CUBE32_LVGL_ENABLED
            bool "Enable LVGL"
            default y
            depends on CUBE32_DISPLAY_ENABLED
            help
                Enable LVGL graphics library integration.
                Requires the display driver to be enabled.
                LVGL provides a feature-rich GUI framework with widgets,
                themes, and animations.

        config CUBE32_LVGL_DOUBLE_BUFFER
            bool "Use Double Buffer"
            default y
            depends on CUBE32_LVGL_ENABLED
            help
                Use double buffering for smoother display updates.
                Requires more memory but reduces flickering.

        config CUBE32_LVGL_USE_SPIRAM
            bool "Use SPIRAM for Buffers"
            default y
            depends on CUBE32_LVGL_ENABLED
            help
                Allocate LVGL display buffers in SPIRAM instead of internal RAM.
                Use this if you have limited internal RAM but have PSRAM available.

        config CUBE32_LVGL_TASK_PRIORITY
            int "LVGL Task Priority"
            default 4
            range 1 24
            depends on CUBE32_LVGL_ENABLED
            help
                Priority of the LVGL task. Higher values mean higher priority.

        config CUBE32_LVGL_TASK_STACK_SIZE
            int "LVGL Task Stack Size"
            default 8192
            range 4096 16384
            depends on CUBE32_LVGL_ENABLED
            help
                Stack size in bytes for the LVGL task.
    endmenu

    menu "Touch Configuration"
        config CUBE32_TOUCH_ENABLED
            bool "Enable Touch"
            default y
            help
                Enable touch driver initialization.
    endmenu

    menu "Audio Configuration"
        config CUBE32_AUDIO_ENABLED
            bool "Enable Audio"
            default n
            help
                Enable audio codec driver initialization.
                Uses ES8311 for output and ES7210 for microphone input.

        config CUBE32_AUDIO_INPUT_SAMPLE_RATE
            int "Input Sample Rate (Hz)"
            default 16000
            range 8000 48000
            depends on CUBE32_AUDIO_ENABLED
            help
                Audio input (microphone) sample rate in Hz.
                Default is 16000 Hz to support AEC which requires 16kHz.
                Common values: 8000, 16000, 24000, 44100, 48000.

        config CUBE32_AUDIO_OUTPUT_SAMPLE_RATE
            int "Output Sample Rate (Hz)"
            default 24000
            range 8000 48000
            depends on CUBE32_AUDIO_ENABLED
            help
                Audio output (speaker) sample rate in Hz.
                Default is 24000 Hz.
                Common values: 8000, 16000, 24000, 44100, 48000.

        config CUBE32_AUDIO_OUTPUT_VOLUME
            int "Output Volume"
            default 70
            range 0 100
            depends on CUBE32_AUDIO_ENABLED
            help
                Default output volume level (0-100).

        config CUBE32_AUDIO_INPUT_GAIN
            int "Input Gain (dB)"
            default 30
            range 0 100
            depends on CUBE32_AUDIO_ENABLED
            help
                Default microphone input gain in dB (0-100).

        choice CUBE32_AUDIO_AEC_MODE
            prompt "AEC Mode"
            default CUBE32_AUDIO_AEC_HW
            depends on CUBE32_AUDIO_ENABLED
            help
                Select acoustic echo cancellation mode.
                HW AEC uses the ES7210 ch1 hardware reference loopback.
                SW AEC uses a software copy of the playback buffer as reference.
                The audio driver automatically clamps input sample rate to 16 kHz
                when AEC is enabled (HW or SW) because esp-sr requires 16 kHz.

            config CUBE32_AUDIO_AEC_NONE
                bool "No AEC"
                help
                    Disable acoustic echo cancellation.
                    Input uses 1 channel (mic only).

            config CUBE32_AUDIO_AEC_HW
                bool "HW AEC (hardware reference loopback)"
                help
                    Hardware reference loopback via ES7210 ch1.
                    Input uses 2 channels (mic + reference).
                    Requires esp-sr afe_aec API in application code.

            config CUBE32_AUDIO_AEC_SW
                bool "SW AEC (software reference)"
                help
                    Software-supplied reference buffer for AEC.
                    Input uses 1 channel (mic only).
                    Application must supply playback frames as reference
                    to esp-sr aec_process().
        endchoice

        config CUBE32_ADC_BUTTON_ENABLED
            bool "Enable ADC Button Array"
            default n
            help
                Enable ADC button array driver initialization.
                Uses a single ADC pin with resistor voltage dividers
                to detect up to 6 different buttons.
                
                Typical resistor divider setup (from 3.3V with 10K pull-up):
                - Button 0: 1.3K  -> ~0.38V (Volume Up)
                - Button 1: 3.3K  -> ~0.82V (Volume Down)
                - Button 2: 5.1K  -> ~1.11V
                - Button 3: 10K   -> ~1.65V (Play/Stop)
                - Button 4: 15K   -> ~1.98V (Mute)
                - Button 5: 27K   -> ~2.41V
    endmenu

