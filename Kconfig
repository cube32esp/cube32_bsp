    menu "USB Input Configuration"
        config CUBE32_USB_INPUT_ENABLED
            bool "Enable USB Input (Keyboard/Mouse)"
            default n
            help
                Enable USB Host HID driver for keyboard and mouse input.
                Uses the ESP32-S3 built-in USB Host controller.
                
                NOTE: USB Input and USB Modem (with USB connection) cannot be
                used at the same time as they both require the USB Host controller.
                Use UART connection for modem if USB Input is needed.
                
                Features:
                - USB HID Keyboard support (boot protocol)
                - USB HID Mouse support (boot protocol)
                - Event queues for keyboard and mouse events
                - Thread-safe operation
                
                NOTE: USB Hubs are NOT supported. Connect devices directly.

        config CUBE32_USB_INPUT_KEYBOARD
            bool "Enable USB Keyboard"
            default y
            depends on CUBE32_USB_INPUT_ENABLED
            help
                Enable USB HID keyboard support.
                Keyboard events are processed using boot protocol for
                maximum compatibility with standard keyboards.

        config CUBE32_USB_INPUT_MOUSE
            bool "Enable USB Mouse"
            default y
            depends on CUBE32_USB_INPUT_ENABLED
            help
                Enable USB HID mouse support.
                Mouse events are processed using boot protocol for
                maximum compatibility with standard mice.

        config CUBE32_USB_INPUT_LVGL_MOUSE
            bool "Add USB Mouse to LVGL"
            default y
            depends on CUBE32_USB_INPUT_ENABLED && CUBE32_USB_INPUT_MOUSE && CUBE32_LVGL_ENABLED
            help
                Automatically add USB mouse input device to LVGL.
                When enabled, USB mouse will control the LVGL cursor
                and can interact with LVGL widgets.
                
                A red circular cursor will be shown to indicate mouse position.
    endmenu

endmenu

